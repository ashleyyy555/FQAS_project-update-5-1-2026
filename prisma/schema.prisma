generator client {
  provider = "prisma-client"
  output   = "../generated/client"
  entrypoints = ["client", "database"]
}

datasource db {
  provider = "postgresql"
  
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id           String    @id @default(cuid())
  passwordHash String
  username     String    @unique
  isAdmin      Boolean   @default(false)
  accounts     Account[]
  sessions     Session[]
}



// --- Packaging QA models ---
model Packaging {
  id                 Int      @id @default(autoincrement())
  testDate           DateTime

  // from UI: productType and productID
  productType        String
  productID          String

  // NEW FIELDS
  construction       String?
  denier             Float?
  color              String?
  additionalFeatures String?

  // existing metrics
  grammage           Float?
  tensileMD          Float?
  tensileCD          Float?
  elongationMD       Float?
  elongationCD       Float?

  // tubing metrics (NEW)
  tubingTensile      Float?
  tubingElongation   Float?
  tubingPeelPeak     Float?
  tubingPeelAvg      Float?

  notes              String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("packaging")
  @@index([testDate])
  @@index([productType])
}





