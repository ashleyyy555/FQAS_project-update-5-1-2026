<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>

        <proxy reverseProxy="true" />

        <rewrite>
            <rules>
                <rule name="NextJS" stopProcessing="true">
                    <match url="(.*)"/>
                    <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}"/>
                </rule>
            </rules>
        </rewrite>

    </system.webServer>
</configuration>
